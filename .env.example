# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sdr:CHANGE_ME@localhost:5432/sdr_agent
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1

# ── Chatwoot ──────────────────────────────────────────────────────────────────
CHATWOOT_URL=https://your-chatwoot.example.com
CHATWOOT_API_TOKEN=CHANGE_ME
CHATWOOT_ACCOUNT_ID=1
# The numeric ID of the bot's agent account in Chatwoot.
# Messages sent by this agent are ignored to prevent self-loops.
CHATWOOT_BOT_SENDER_ID=CHANGE_ME

# ── Qualification ─────────────────────────────────────────────────────────────
# Minimum budget (in BRL) for a lead to be considered qualified.
MIN_BUDGET=5000

# ── Notifications ─────────────────────────────────────────────────────────────
# WhatsApp number to receive admin alerts (format: 5511999999999)
ADMIN_WHATSAPP=5511999999999
